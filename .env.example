# ==========================================
# Database
# For local development OUTSIDE Docker use localhost:5433
# Docker Compose sets this automatically — no need to change for Docker
# ==========================================
DATABASE_URL=postgresql+asyncpg://interiorai:interiorai@localhost:5433/interiorai_db
POSTGRES_DB=interiorai_db
POSTGRES_USER=interiorai
POSTGRES_PASSWORD=interiorai

# ==========================================
# Redis
# For local development OUTSIDE Docker use localhost:6380
# Docker Compose sets this automatically — no need to change for Docker
# ==========================================
REDIS_URL=redis://localhost:6380/0
CELERY_BROKER_URL=redis://localhost:6380/0
CELERY_RESULT_BACKEND=redis://localhost:6380/1

# ==========================================
# Storage
# Configuration for file storage
# ==========================================
STORAGE_BACKEND=local
STORAGE_LOCAL_PATH=/app/media
MEDIA_URL_PREFIX=/media

# ==========================================
# AI Providers
# API keys and endpoints for AI integrations
# ==========================================
OPENAI_API_KEY=sk-proj-example-key-12345
FLUX_ENABLED=False
FLUX_API_URL=https://api.bfl.ml/v1
FLUX_API_KEY=example-flux-key

# ==========================================
# App
# General application configuration
# ==========================================
MAX_UPLOAD_SIZE_MB=20
ALLOWED_MIME_TYPES=image/jpeg,image/png,image/webp

# ==========================================
# Rate Limiting
# Controls for API rate limiting
# ==========================================
RATE_LIMIT_ENABLED=False
RATE_LIMIT_GENERATIONS_PER_DAY=50

# ==========================================
# Observability
# Logging and environment settings
# ==========================================
LOG_LEVEL=INFO
APP_ENV=development
